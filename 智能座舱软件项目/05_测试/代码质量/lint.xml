    <!-- 文档 -->
    <issue id="MissingVersion" severity="informational" />
    <issue id="RequiredFeature" severity="informational" />
    
    <!-- ============================================================ -->
    <!-- 国际化 -->
    <!-- ============================================================ -->
    
    <issue id="RtlSymmetry" severity="informational" />
    <issue id="RtlHardcoded" severity="informational" />
    <issue id="RtlEnabled" severity="informational" />
    
    <!-- ============================================================ -->
