    <!-- ============================================================ -->
    
    <!-- 依赖版本在build.gradle集中管理 -->
    <issue id="GradleDependency" severity="ignore" />
    <issue id="GradleDynamicVersion" severity="error" />
    <issue id="OldTargetApi" severity="ignore" />
    <issue id="OldVersionApi" severity="ignore" />
    <issue id="ExpiredTargetSdkVersion" severity="error" />
    <issue id="ExpiredTargetSdkInLibrary" severity="error" />
    
    <!-- ============================================================ -->
    <!-- 拼写和文本 -->
    <!-- ============================================================ -->
    
    <issue id="Typos" severity="ignore" />
    <issue id="ChronometerCountDown" severity="ignore" />
    
