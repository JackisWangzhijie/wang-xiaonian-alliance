<?xml version="1.0" encoding="UTF-8"?>
<!--
  Android Lint 规则配置 - ASPICE Level 3 完整版
  智能座舱主交互系统
  版本: 2.0
-->
<lint>

    <!-- ============================================================ -->
    <!-- 致命错误 - 阻塞构建 (Fatal) -->
    <!-- ============================================================ -->
    
    <!-- 编译错误 -->
    <issue id="NewApi" severity="fatal" />
    <issue id="InlinedApi" severity="fatal" />
    <issue id="OverrideAbstract" severity="fatal" />
    <issue id="MissingSuperCall" severity="fatal" />
    
    <!-- 资源错误 -->
    <issue id="MissingTranslation" severity="fatal" />
    <issue id="ExtraTranslation" severity="fatal" />
    <issue id="MissingDefaultResource" severity="fatal" />
    
    <!-- ============================================================ -->
    <!-- 严重错误 - 必须修复 (Error) -->
    <!-- ============================================================ -->
    
    <!-- 安全性 -->
    <issue id="BadHostnameVerifier" severity="error" />
    <issue id="TrustAllX509TrustManager" severity="error" />
    <issue id="AllowBackup" severity="error" />
    <issue id="ExportedService" severity="error" />
    <issue id="ExportedReceiver" severity="error" />
    <issue id="ExportedContentProvider" severity="error" />
    <issue id="SetJavaScriptEnabled" severity="error" />
    <issue id="WebViewClientOnReceivedSslError" severity="error" />
    <issue id="AddJavascriptInterface" severity="error" />
    <issue id="UnsafeNativeCodeLocation" severity="error" />
    <issue id="UnsafeProtectedBroadcastReceiver" severity="error" />
    
    <!-- 硬编码文本 - 国际化要求 -->
    <issue id="HardcodedText" severity="error">
        <ignore path="**/test/**" />
        <ignore path="**/androidTest/**" />
    </issue>
    
    <!-- 权限 -->
    <issue id="MissingPermission" severity="error" />
    <issue id="PermissionImpliesUnsupportedChromeOsHardware" severity="error" />
    <issue id="UnusedPermission" severity="warning" />
    <issue id="UsesPermission" severity="warning" />
    
    <!-- 弃用API -->
    <issue id="Deprecation" severity="error" />
    <issue id="DeprecatedProvider" severity="error" />
    <issue id="DeprecatedSinceApi" severity="error" />
    
    <!-- 空安全 -->
    <issue id="NullSafeMutableLiveData" severity="error" />
    <issue id="UnknownNullness" severity="error" />
    <issue id="KotlinNullnessAnnotation" severity="error" />
    
    <!-- 资源泄露 -->
    <issue id="Recycle" severity="error" />
    <issue id="Wakelock" severity="error" />
    <issue id="WakelockTimeout" severity="error" />
    <issue id="MediaCapabilities" severity="error" />
    <issue id="UnclosedCloseable" severity="error" />
    
    <!-- 线程安全 -->
    <issue id="StaticFieldLeak" severity="error" />
    <issue id="ThreadSafety" severity="error" />
    
    <!-- ============================================================ -->
    <!-- 高危警告 - 必须修复 (Warning) -->
    <!-- ============================================================ -->
    
    <!-- 内存泄露风险 -->
    <issue id="HandlerLeak" severity="warning" />
    <issue id="Leakage" severity="warning" />
    <issue id="FragmentLiveDataObserve" severity="warning" />
    <issue id="AutoDispose" severity="warning" />
    
    <!-- 性能问题 -->
    <issue id="UseSparseArrays" severity="warning" />
    <issue id="UseValueOf" severity="warning" />
    <issue id="ViewTag" severity="warning" />
    <issue id="InefficientWeight" severity="warning" />
    <issue id="NestedWeights" severity="warning" />
    <issue id="Overdraw" severity="warning" />
    <issue id="UnusedNamespace" severity="warning" />
    <issue id="ObsoleteLayoutParam" severity="warning" />
    <issue id="MergeRootFrame" severity="warning" />
    <issue id="DisableBaselineAlignment" severity="warning" />
    <issue id="InefficientPaint" severity="warning" />
    
    <!-- 布局性能 -->
    <issue id="ViewHolder" severity="warning" />
    <issue id="DrawAllocation" severity="warning" />
    <issue id="CustomViewStyleable" severity="warning" />
    <issue id="UselessParent" severity="warning" />
    <issue id="TooManyViews" severity="warning" />
    <issue id="TooDeepLayout" severity="warning" />
    
    <!-- 并发问题 -->
    <issue id="CheckResult" severity="warning" />
    <issue id="UseCheckPermission" severity="warning" />
    <issue id="DefaultLocale" severity="warning" />
    <issue id="SimpleDateFormat" severity="warning" />
    
    <!-- 数据绑定 -->
    <issue id="DataBindingWithoutKapt" severity="warning" />
    <issue id="BindingInfo" severity="warning" />
    
    <!-- ============================================================ -->
    <!-- Kotlin 特定规则 -->
    <!-- ============================================================ -->
    
    <issue id="KotlinPropertyAccess" severity="warning" />
    <issue id="LambdaLast" severity="warning" />
    <issue id="NoHardKeywords" severity="warning" />
    <issue id="SyntheticAccessor" severity="warning" />
    <issue id="NonKaptIssue" severity="warning" />
    <issue id="KaptUsageInsteadOfKsp" severity="informational" />
    
    <!-- ============================================================ -->
