    <!-- 驾驶安全 -->
    <issue id="CarPermission" severity="error" />
    <issue id="CarRestrictedPermission" severity="error" />
    
    <!-- ============================================================ -->
    <!-- 安全增强规则 -->
    <!-- ============================================================ -->
    
    <!-- SQL注入防护 -->
    <issue id="SQLiteString" severity="warning" />
