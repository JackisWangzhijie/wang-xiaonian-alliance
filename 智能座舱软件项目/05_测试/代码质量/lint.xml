    <issue id="ComposePreviewNaming" severity="warning" />
    <issue id="ComposePreviewPublic" severity="warning" />
    <issue id="ComposeReusedModifierInstance" severity="error" />
    <issue id="ComposeUnstableCollections" severity="warning" />
    <issue id="ComposeUnstableReceiver" severity="warning" />
    <issue id="ComposeM2Api" severity="warning" />
    <issue id="ComposeModelClassInCompositionWithStateInstatiation" severity="warning" />
    <issue id="ComposeSuspiciousCompositionLocalModifierRead" severity="warning" />
    <issue id="ComposeCollectionItemReuse" severity="warning" />
    <issue id="ComposeStateNotRemembered" severity="error" />
    <issue id="ComposeAutoboxingStateCreation" severity="warning" />
